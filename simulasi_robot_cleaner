# ─────────────────────────────────────────────
ROOM_WIDTH  = 20          # Lebar ruangan (satuan koordinat)
ROOM_HEIGHT = 15          # Tinggi ruangan
GRID_RES    = 0.25        # Resolusi grid pembersihan (ukuran per sel)
ROBOT_RADIUS = 0.5        # Radius robot (lingkaran)
ROBOT_SPEED  = 0.18       # Kecepatan robot per langkah
SENSOR_RANGE = 1.8        # Jarak sensor pendeteksi obstacle
CLEAN_RADIUS = 0.7        # Radius area yang dibersihkan per langkah
TRAIL_MAXLEN = 180        # Panjang maksimum jejak lintasan

# Palet warna modern
COLOR_FLOOR_DIRTY  = "#1a1a2e"   # Lantai kotor (gelap biru-tua)
COLOR_FLOOR_CLEAN  = "#16213e"   # Lantai bersih (sedikit lebih terang)
COLOR_CLEAN_MARK   = "#0f3460"   # Tanda area dibersihkan
COLOR_OBSTACLE_BG  = "#533483"   # Warna bayangan obstacle
